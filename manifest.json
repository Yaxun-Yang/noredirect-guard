{
  "manifest_version": 3,
  "name": "NoRedirect Guard",
  "version": "1.0.0",
  "description": "Blocks automatic redirects and popups. Your own taps/clicks are never affected.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoRedirect Guard"
  }
}
